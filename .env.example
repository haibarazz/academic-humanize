# Academic Humanize environment template
# Copy this file to .env and fill in only the provider you use.

# OpenAI-compatible API endpoint used by scripts/utils/api_client.py.
# Examples:
#   OpenAI:      CUSTOM_API_URL=https://api.openai.com/v1
#   DeepSeek:    CUSTOM_API_URL=https://api.deepseek.com/v1
#   OpenRouter:  CUSTOM_API_URL=https://openrouter.ai/api/v1
#   SiliconFlow: CUSTOM_API_URL=https://api.siliconflow.cn/v1
CUSTOM_API_KEY=
CUSTOM_API_URL=

# Default models for API prediction and rejected-candidate generation.
AH_MODEL=openai/gpt-4o-mini
TRANSLATION_MODEL=openai/gpt-4o-mini

# Default judge model for evaluation/judge/llm_judge.py.
AH_JUDGE_MODEL=deepseek-v4-flash
JUDGE_MODEL=deepseek-v4-flash

# API runtime controls.
API_RATE_LIMIT=60
API_429_SLEEP_SECONDS=60
API_MAX_CONCURRENCY=4

# OpenRouter optional headers and reasoning controls.
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Academic Humanize
OPENROUTER_DISABLE_REASONING=true

# HuggingFace / AutoDL controls.
HF_HOME=
HF_ENDPOINT=https://hf-mirror.com
TRANSFORMERS_OFFLINE=0
HF_HUB_OFFLINE=0

# Optional detector endpoint, only needed for evaluation/detector.
FASTDETECT_API_URL=
FASTDETECT_API_KEY=
FASTDETECT_DETECTOR=
